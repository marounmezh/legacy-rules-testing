--the bottom chunk extracts the number of apps per rule as well as actual NM impact from them--
-----------------------------------------------------------------------------------------------
SELECT 
inactive_legacy_flag1
,repo_legacy_flag2
,omf_co_legacy_flag3
,recent_bankruptcy_legacy_flag4
,debt_counseling_legacy_flag5
,dq_6mo_legacy_flag6
,payments_trades_legacy_flag7
,co_over5k_12mo_legacy_flag8

,CASE
    WHEN (inactive_legacy_flag1 + repo_legacy_flag2 + omf_co_legacy_flag3 + recent_bankruptcy_legacy_flag4 + debt_counseling_legacy_flag5 + dq_6mo_legacy_flag6 + payments_trades_legacy_flag7 + co_over5k_12mo_legacy_flag8 > 1) OR (inactive_legacy_flag1 + repo_legacy_flag2 + omf_co_legacy_flag3 + recent_bankruptcy_legacy_flag4 + debt_counseling_legacy_flag5 + dq_6mo_legacy_flag6 + payments_trades_legacy_flag7 + co_over5k_12mo_legacy_flag8 = 0)
    THEN 'Y'
    ELSE 'N'
END AS multiple_flags
,COUNT(DISTINCT(appl_key)) as total_apps
--the line below is a sanity check that all apps are unique
--,COUNT(appl_key) as test_total_apps
,COUNT(DISTINCT(appl_key))*6 as annual_total_apps
,sum(case when acct_key > 0 then 1 else 0 end) as book
,sum(case when acct_key > 0 then 1 else 0 end)*6 as annual_book
,SUM(NEW_MONEY) AS actual_NM
,SUM(NEW_MONEY)*6 AS annual_actual_NM

FROM df_legacy_rules
WHERE multiple_flags = 'N'
GROUP BY 1,2,3,4,5,6,7,8,9;
----------------------------------------------------------------------------------------------------
/*the following chunk will simulated the NM impact if we were to relax the rules--
We start by calculating the average new money and PTR of each initial risk grade to have a benchmark
Then, we assigned the values based on initial risk grade to the data for all RGs. Then, we collapse
and add by LEGACY FLAG and RG to get the simulated new money impact of deleting a rule*/
----------------------------------------------------------------------------------------------------
--NM and PTR by Initial RG
SELECT PRI_INIT_RG_NO
,SUM(NEW_MONEY) AS actual_NM
,COUNT(DISTINCT(appl_key)) as total_apps
,sum(case when acct_key > 0 then 1 else 0 end) as book
,(book*100/total_apps) AS PTR
,(actual_NM/book) AS average_NM
FROM df_legacy_rules
WHERE PRI_INIT_RG_NO NOT IN (0)
GROUP BY 1
ORDER BY PRI_INIT_RG_NO;

--We copied the results to an excel sheet, now we hard code them into the final driver table. We can also copy these results from the resulting table from the chunk above. I hard coded them in for simplicity. The number I hard coded in is PTR times Average NM per twentile. Given that all our rows are unique (look at 188-189), summing them will give us the NM impact for each rule
