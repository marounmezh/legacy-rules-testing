    WHEN PRI_INIT_RG_NO = 9 THEN 1072.008
    WHEN PRI_INIT_RG_NO = 10 THEN 1008.959
    WHEN PRI_INIT_RG_NO = 11 THEN 766.7576
    WHEN PRI_INIT_RG_NO = 12 THEN 686.0425
    WHEN PRI_INIT_RG_NO = 13 THEN 621.2745
    WHEN PRI_INIT_RG_NO = 14 THEN 555.23
    WHEN PRI_INIT_RG_NO = 15 THEN 341.4836
